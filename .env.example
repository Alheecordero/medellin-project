# =============================================================================
# EJEMPLO DE CONFIGURACIÓN - NO USAR EN PRODUCCIÓN
# Copiar a .env y ajustar valores según el entorno
# =============================================================================

# Django
SECRET_KEY='your-secret-key-here'
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost

# Base de datos PostgreSQL/PostGIS
DATABASE_URL='postgis://user:password@host:5432/dbname'

# Google Cloud Storage (legacy — omitir si usas R2)
GS_BUCKET_NAME='vivemedellin-bucket'
GS_CREDENTIALS_PATH='path/to/credentials.json'
USE_GCS_IN_DEBUG=False

# Cloudflare API (scripts/deploy/cloudflare_geo_block_countries.sh)
# Permisos: Zone Firewall Services Edit + Zone Read en vivemedellin.co
CLOUDFLARE_ACCOUNT_ID=04310bfc9de731f6988144da18a83213
CLOUDFLARE_API_TOKEN='your-cloudflare-api-token'
CLOUDFLARE_ZONE_NAME='vivemedellin.co'
# CLOUDFLARE_ZONE_ID='opcional-si-lo-conoces'

# Cloudflare R2 (recomendado para ViveMedellín)
R2_ENDPOINT_URL='https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com'
R2_BUCKET='vivemedellin-media'
R2_ACCESS_KEY_ID='your-r2-access-key'
R2_SECRET_ACCESS_KEY='your-r2-secret-key'
R2_PUBLIC_BASE_URL='https://img.vivemedellin.co'

# Redis Cache
REDIS_URL='redis://127.0.0.1:6379/1'

# Google APIs
GOOGLE_API_KEY='your-google-api-key'
GOOGLE_ANALYTICS_ID='G-XXXXXXXXXX'

# Seguridad (solo producción)
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Debug toolbar (solo desarrollo)
SHOW_DEBUG_TOOLBAR=False
